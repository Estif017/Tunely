{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/expo/bin/cli", "start", "--web"],
      "port": 8081
    },
    {
      "name": "Expo (Android)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    },
    {
      "name": "Expo (Web)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "web"],
      "port": 8081
    }
  ]
}
